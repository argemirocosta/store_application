	<parameter name="datainicio" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="datafim" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT fp.descricao, sum(valor) AS total
FROM vendas.venda v 
INNER JOIN vendas.forma_pagamento fp ON (v.id_forma_pagamento = fp.id)
WHERE v."data" >=  $P{datainicio}  AND v."data" <=  $P{datafim} 
AND v.cancelada IS NOT TRUE
GROUP BY fp.descricao 
ORDER BY fp.descricao]]>
	</queryString>
	<field name="descricao" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="descricao"/>
